<% layout("layout/boilerPlate") -%>

     <div class="offset-4">
        <h2>Edit your list:</h2>
    </div>
    <div class="row offset-4" >
        <div class="col-6">
            <form method="post" action="/listing/<%= list._id %>?_method=put"  class="needs-validation" novalidate enctype="multipart/form-data">
            <div class="mb-3">
                <label for="name" class="form-label">Title</label>
                <input type="text" class="form-control" id="name" name="listing[title]" value="<%= list.title %>" placeholder="Enter your tittle" required>
                <div class="invalid-feedback">
                Please choose a title.
                </div>
            </div>
            <div class="mb-3">
                <label for="name" class="form-label">Description</label>
                <textarea name="listing[description]" class="form-control"  id="name" required><%=list.description%></textarea>
                <div class="invalid-feedback">
                Please choose a description.
                </div>
            </div>

            <div class="mb-3" >
                <p> Orginal Image </p>
                <img src="<%= orginalImage %>" alt="image"  class="ogImage">
            </div>
            
            <div class="mb-3">
                <label for="name" class="form-label">Image</label>
                <input type="file" class="form-control" id="name" name="image" value="<%= list.image.url %>" placeholder="Enter your image" >
                <div class="invalid-feedback">
                Please choose a image.
                </div>
            </div>
            
            <div class="row">
                <div class="mb-3 col-md-4">
                <label for="name" class="form-label">Price</label>
                <input type="text" class="form-control" id="name" name="listing[price]" value="<%= list.price %>" placeholder="Enter your price" required>
                <div class="invalid-feedback">
                Please choose a Price.
                </div>
                </div>

                  
                <div class="mb-3 col-md-8">
                    <label for="name" class="form-label">Country</label>
                    <input type="text" class="form-control" id="name" name="listing[country]"  value="<%= list.country %>" placeholder="Enter your country" required>
                    <div class="invalid-feedback">
                    Please choose a country.
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <label for="name" class="form-label">Location</label>
                <input type="text" class="form-control" id="name" name="listing[location]" value="<%= list.location %>" placeholder="Enter your location" required>
                <div class="invalid-feedback">
                Please choose a location.
                </div>
            </div>
      
            <button class="btn custom-btn">edit</button>
            </form>
        </div>
    </div>
    
    