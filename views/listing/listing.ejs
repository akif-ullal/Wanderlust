  <div class="filters-container container my-3">

  <!-- Hamburger button for small/medium screens -->
  <button class="btn btn-outline-secondary d-md-none mb-2" type="button" data-bs-toggle="collapse" data-bs-target="#filtersCollapse" aria-expanded="false" aria-controls="filtersCollapse">
    <i class="fa-solid fa-bars"></i> Filters
  </button>

  <!-- Filters row (collapsible) -->
  <div class="collapse d-md-flex flex-wrap justify-content-start align-items-center gap-3" id="filtersCollapse">

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-fire filter-icon"></i>
      <p class="filter-text">Trending</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-bed filter-icon"></i>
      <p class="filter-text">Rooms</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-mountain-city filter-icon"></i>
      <p class="filter-text">Iconic Cities</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-mountain filter-icon"></i>
      <p class="filter-text">Mountain</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-brands fa-fort-awesome filter-icon"></i>
      <p class="filter-text">Castles</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-person-swimming filter-icon"></i>
      <p class="filter-text">Pools</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-campground filter-icon"></i>
      <p class="filter-text">Camping</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-cow filter-icon"></i>
      <p class="filter-text">Farms</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-snowflake filter-icon"></i>
      <p class="filter-text">Arctic</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-igloo filter-icon"></i>
      <p class="filter-text">Doms</p>
    </div>

    <div class="filter d-flex flex-column align-items-center">
      <i class="fa-solid fa-ship filter-icon"></i>
      <p class="filter-text">Boat House</p>
    </div>

    <!-- Toggle Switch -->
    <div class="toggle-switch mt-2">
      <div class="form-check-reverse  form-switch custom-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">Display Total After Taxes</label>
      </div>
    </div>

  </div>
</div>



  <div class="content ">
    <div class="list-content">
      <div class="row row-cols-1 row-cols-sm-1 row-cols-md-2 row-cols-lg-3 g-4">

        <% for (let list of listing) { %>
          
              <div class="card listing-card col" style="width: 20rem">
                <a href="/listing/<%=list._id%>">
                  <img src="<%= list.image.url %>" class="card-img-top listing-img" alt="listing.img" style="height: 20rem">
                    <div class="card-img-overlay"></div>
                    <div class="card-body">
                        <p class="card-text">
                            <b><%=list.title%></b>
                            <br>
                            &#8377;<%=(list.price === null || list.price === undefined || list.price === "")
                              ? "N/A" : list.price.toLocaleString("en-IN")%>/night &nbsp;
                              <i class="gst">+18% GST</i>
                        </p>
                    </div>
                </a>
              </div>
          
        <% } %>

      </div>
    </div>
  </div>

  <script src="/js/showTax.js"></script>
