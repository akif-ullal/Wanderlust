
<% layout("layout/boilerPlate") -%>
<% if (listing && listing.length > 0) { %>
  <div class="row row-cols-1 row-cols-sm-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% for (let list of listing) { %>
      <div class="card listing-card col" style="width: 20rem">
        <a href="/listing/<%= list._id %>">
          <img src="<%= list.image.url %>" class="card-img-top listing-img" alt="listing.img" style="height: 20rem">
          <div class="card-img-overlay"></div>
          <div class="card-body">
            <p class="card-text">
              <b><%= list.title %></b><br>
              &#8377;<%= (list.price === null || list.price === undefined || list.price === "") ? "N/A" : list.price.toLocaleString("en-IN") %>/night &nbsp;
              <i class="gst">+18% GST</i>
            </p>
          </div>
        </a>
      </div>
    <% } %>
  </div>
<% } else { %>
  <p style="text-align:center; font-size:1.2rem; margin-top:2rem;">
    No results found.
  </p>
<% } %>
